<Page x:Class="CinemaApp.Pages.BookingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление билета">
    <StackPanel Margin="20" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Оформление билета" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <TextBlock Text="Фильм:"/>
        <TextBlock x:Name="TbFilm" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <TextBlock Text="Зал:"/>
        <TextBlock x:Name="TbHall" Margin="0,0,0,10"/>
        
        <TextBlock Text="Дата и время:"/>
        <TextBlock x:Name="TbDateTime" Margin="0,0,0,10"/>
        
        <TextBlock Text="Место:"/>
        <TextBlock x:Name="TbSeat" Margin="0,0,0,10"/>
        
        <TextBlock Text="Цена:"/>
        <TextBlock x:Name="TbPrice" FontWeight="Bold" FontSize="16" Margin="0,0,0,20"/>
        
        <Button Content="Подтвердить покупку" Padding="10,5" Click="BtnConfirm_Click" Margin="0,0,0,5"/>
        <Button Content="Назад" Padding="10,5" Click="BtnBack_Click"/>
    </StackPanel>
</Page>
