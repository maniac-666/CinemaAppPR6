<Page x:Class="CinemaApp.Pages.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Выбор места">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="Назад" Grid.Row="0" HorizontalAlignment="Left"
                Padding="10,5" Click="BtnBack_Click" Margin="0,0,0,10"/>

        <TextBlock x:Name="TbInfo" Grid.Row="1" FontSize="14" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="ЭКРАН" HorizontalAlignment="Center"
                   Background="LightGray" Padding="50,5" Margin="0,0,0,15"/>

        <StackPanel x:Name="SeatsPanel" Grid.Row="3" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Зеленый=свободно  Красный=занято  Желтый=выбрано" 
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button x:Name="BtnBook" Content="Оформить билет" Padding="15,5"
                    Click="BtnBook_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Page>
