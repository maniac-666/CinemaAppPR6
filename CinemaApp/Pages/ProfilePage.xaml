<Page x:Class="CinemaApp.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="На главную" Padding="10,5" Click="BtnBack_Click" Margin="0,0,10,0"/>
            <Button Content="Выйти" Padding="10,5" Click="BtnLogout_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Личный кабинет" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TbName"/>
            <TextBlock x:Name="TbLogin"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Мои билеты:" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

        <ListBox x:Name="LbTickets" Grid.Row="3">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Sessions.Films.Title}" FontWeight="Bold"/>
                        <TextBlock>
                            <Run Text="Зал "/>
                            <Run Text="{Binding Sessions.Halls.Number, Mode=OneWay}"/>
                            <Run Text=" | Ряд "/>
                            <Run Text="{Binding SeatRow, Mode=OneWay}"/>
                            <Run Text=", Место "/>
                            <Run Text="{Binding SeatNumber, Mode=OneWay}"/>
                            <Run Text=" | "/>
                            <Run Text="{Binding Price, Mode=OneWay}"/>
                            <Run Text=" руб."/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
